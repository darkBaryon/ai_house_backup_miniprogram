page {
  --page-bg: #f3f4f6;
  --surface: #ffffff;
  --surface-muted: #f1f2f5;
  --text-primary: #121722;
  --text-secondary: #565f72;
  --text-tertiary: #8f98aa;
  --line: #e7e9ee;
  --brand: #161d2b;
  --brand-soft: #edf0f6;
  --accent: #1fa77b;
  --warn: #f0a94b;
  --radius-lg: 24rpx;
  --radius-md: 16rpx;
  --shadow-card: 0 8rpx 24rpx rgba(14, 20, 36, 0.05);
}

page {
  background: var(--page-bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  font-family: 'PingFang SC', 'SF Pro SC', 'Helvetica Neue', sans-serif;
}

view,
text,
button,
input,
scroll-view,
swiper,
swiper-item,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 24rpx;
}

.section-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.card-link {
  color: var(--brand);
  font-size: 24rpx;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 176rpx;
  height: 80rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #171e2d 0%, #2a354e 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-primary::after,
.btn-ghost::after {
  border: 0;
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 176rpx;
  height: 80rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 600;
}

.price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand);
}

.price-unit {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.muted {
  color: var(--text-secondary);
}

.tiny {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
