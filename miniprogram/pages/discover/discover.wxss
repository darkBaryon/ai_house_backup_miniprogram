.search-shell {
  padding: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
}

.search-text {
  color: var(--text-tertiary);
}

.search-link {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.filter-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 24rpx;
}

.filter-chip-active {
  background: var(--brand-soft);
  color: var(--brand);
}

.smart-bar {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-md);
  background: #edf9f5;
}

.smart-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: var(--accent);
}

.smart-copy {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
  color: #2f6f62;
}

.list-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-cover {
  height: 220rpx;
  background:
    linear-gradient(135deg, rgba(31, 94, 255, 0.12), rgba(246, 185, 76, 0.16)),
    linear-gradient(45deg, #e4ebff 0%, #f8fbff 100%);
}

.list-body {
  padding: 22rpx 24rpx 24rpx;
}

.list-top,
.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
}

.favorite {
  color: var(--brand);
  font-size: 24rpx;
}

.list-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.empty-card {
  padding: 28rpx;
}

.empty-copy {
  margin: 12rpx 0 22rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
