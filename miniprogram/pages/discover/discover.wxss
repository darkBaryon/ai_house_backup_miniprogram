.discover-hero {
  padding: 26rpx 26rpx 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 244, 179, 0.86), transparent 34%),
    linear-gradient(150deg, #ffef9f 0%, #ffd95d 38%, #fff4cb 100%);
}

.discover-brand-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.discover-brand {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2430;
}

.discover-brand-copy {
  font-size: 22rpx;
  color: rgba(31, 36, 48, 0.72);
}

.discover-title {
  margin-bottom: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #1f2430;
}

.discover-highlight-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 0 18rpx;
}

.discover-highlight-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
  color: #3a4353;
}

.discover-cta-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.discover-cta {
  min-width: 200rpx;
}

.discover-cta-note {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(31, 36, 48, 0.72);
}

.recommend-shell {
  padding: 24rpx;
}

.recommend-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.recommend-state {
  padding: 26rpx 8rpx 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.recommend-state-error {
  color: #c34b40;
}

.recommend-card {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(24, 39, 75, 0.06);
}

.recommend-cover-image-wrap {
  position: relative;
  height: 200rpx;
  background: #eef3fb;
}

.recommend-cover-image {
  display: block;
  width: 100%;
  height: 200rpx;
}

.recommend-cover {
  position: relative;
  height: 200rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.3), transparent 32%),
    linear-gradient(135deg, rgba(31, 94, 255, 0.16), rgba(246, 185, 76, 0.24)),
    linear-gradient(180deg, #dfe8ff 0%, #f8f9ff 100%);
}

.recommend-tag {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 36, 48, 0.82);
  color: #ffffff;
  font-size: 20rpx;
}

.recommend-body {
  padding: 20rpx 20rpx 22rpx;
}

.recommend-area {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.recommend-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.recommend-detail {
  display: block;
  min-height: 64rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.recommend-price-row {
  margin-top: 14rpx;
}

.recommend-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #da493c;
}

.search-shell {
  padding: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
}

.search-text {
  color: var(--text-tertiary);
}

.search-link {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.filter-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 24rpx;
}

.filter-chip-active {
  background: var(--brand-soft);
  color: var(--brand);
}

.smart-bar {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-md);
  background: #edf9f5;
}

.smart-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: var(--accent);
}

.smart-copy {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
  color: #2f6f62;
}

.list-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-cover {
  height: 220rpx;
  background:
    linear-gradient(135deg, rgba(31, 94, 255, 0.12), rgba(246, 185, 76, 0.16)),
    linear-gradient(45deg, #e4ebff 0%, #f8fbff 100%);
}

.list-image {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #eef3fb;
}

.list-body {
  padding: 22rpx 24rpx 24rpx;
}

.list-top,
.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
}

.favorite {
  color: var(--brand);
  font-size: 24rpx;
}

.list-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.empty-card {
  padding: 28rpx;
}

.empty-copy {
  margin: 12rpx 0 22rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.discover-guide-card {
  margin-top: 20rpx;
}

.discover-showcase-card {
  padding: 28rpx;
}

.showcase-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 0;
}

.showcase-item {
  box-sizing: border-box;
  width: 50%;
  padding: 0 8rpx;
}

.showcase-item-inner {
  height: 100%;
  padding: 22rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 250, 233, 0.95) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1rpx solid rgba(246, 185, 76, 0.18);
}

.showcase-badge {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 94, 255, 0.08);
  color: var(--brand);
  font-size: 20rpx;
  font-weight: 600;
}

.showcase-title {
  display: block;
  margin: 18rpx 0 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.showcase-meta {
  display: block;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.showcase-price {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #d94b3d;
}

.reason-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.reason-copy {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
