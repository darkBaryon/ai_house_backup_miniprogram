.discover-hero {
  padding: 24rpx 24rpx 22rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 244, 179, 0.86), transparent 34%),
    linear-gradient(150deg, #ffef9f 0%, #ffd95d 38%, #fff4cb 100%);
}

.discover-brand-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.discover-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.45), transparent 44%),
    linear-gradient(145deg, #1f2430 0%, #313848 100%);
  color: #fff6cf;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.discover-brand-meta {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.discover-brand {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2430;
}

.discover-brand-copy {
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(31, 36, 48, 0.72);
}

.discover-title {
  margin-bottom: 14rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.32;
  color: #1f2430;
}

.discover-cta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.discover-cta {
  min-width: 188rpx;
}

.discover-cta-note {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(31, 36, 48, 0.72);
}

.recommend-shell {
  padding: 24rpx;
}

.recommend-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.recommend-state {
  padding: 26rpx 8rpx 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.recommend-state-error {
  color: #c34b40;
}

.recommend-card {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(24, 39, 75, 0.06);
}

.recommend-cover-image-wrap {
  position: relative;
  height: 200rpx;
  background: #eef3fb;
}

.recommend-cover-image {
  display: block;
  width: 100%;
  height: 200rpx;
}

.recommend-cover {
  position: relative;
  height: 200rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.3), transparent 32%),
    linear-gradient(135deg, rgba(31, 94, 255, 0.16), rgba(246, 185, 76, 0.24)),
    linear-gradient(180deg, #dfe8ff 0%, #f8f9ff 100%);
}

.recommend-tag {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 36, 48, 0.82);
  color: #ffffff;
  font-size: 20rpx;
}

.recommend-body {
  padding: 20rpx 20rpx 22rpx;
}

.recommend-area {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.recommend-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.recommend-detail {
  display: block;
  min-height: 64rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.recommend-price-row {
  margin-top: 14rpx;
}

.recommend-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #da493c;
}

.search-shell {
  padding: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
}

.search-input {
  flex: 1;
  min-width: 0;
  color: var(--text-primary);
  font-size: 26rpx;
}

.search-link {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.quick-preset-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.quick-preset-title {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.quick-more-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
}

.quick-preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.quick-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.quick-chip-label {
  line-height: 1.2;
}

.quick-chip-active {
  background: var(--brand-soft);
  color: var(--brand);
}

.search-filter-note {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.advanced-panel {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7faff;
  border: 1rpx solid #e9eef8;
}

.advanced-group + .advanced-group {
  margin-top: 16rpx;
}

.advanced-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.advanced-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.advanced-chip {
  padding: 10rpx 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: var(--text-secondary);
  font-size: 22rpx;
  border: 1rpx solid #e8edf6;
}

.advanced-chip-active {
  background: var(--brand-soft);
  border-color: rgba(31, 94, 255, 0.2);
  color: var(--brand);
}

.price-range-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.price-input {
  flex: 1;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  font-size: 22rpx;
}

.price-sep {
  width: 24rpx;
  text-align: center;
  color: var(--text-tertiary);
}

.advanced-switches {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.advanced-switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf6;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.advanced-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.advanced-btn {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  font-size: 24rpx;
}

.public-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.public-grid .recommend-card {
  width: 100%;
  flex: none;
}

.public-grid .recommend-cover-image-wrap,
.public-grid .recommend-cover,
.public-grid .recommend-cover-image {
  height: 112rpx;
}

.public-grid .recommend-body {
  padding: 12rpx 14rpx 14rpx;
}

.public-grid .recommend-area {
  margin-bottom: 4rpx;
  font-size: 20rpx;
}

.public-grid .recommend-title {
  margin-bottom: 4rpx;
  font-size: 22rpx;
}

.public-grid .recommend-detail {
  min-height: 0;
  font-size: 18rpx;
  line-height: 1.45;
}

.public-grid .recommend-price {
  font-size: 24rpx;
}

.public-grid .recommend-price-row {
  margin-top: 8rpx;
}

.smart-bar {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-md);
  background: #edf9f5;
}

.smart-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: var(--accent);
}

.smart-copy {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
  color: #2f6f62;
}

.list-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-cover {
  height: 220rpx;
  background:
    linear-gradient(135deg, rgba(31, 94, 255, 0.12), rgba(246, 185, 76, 0.16)),
    linear-gradient(45deg, #e4ebff 0%, #f8fbff 100%);
}

.list-image {
  display: block;
  width: 100%;
  height: 220rpx;
  background: #eef3fb;
}

.list-body {
  padding: 22rpx 24rpx 24rpx;
}

.list-top,
.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
}

.favorite {
  color: var(--brand);
  font-size: 24rpx;
}

.list-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.empty-card {
  padding: 28rpx;
}

.empty-copy {
  margin: 12rpx 0 22rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.discover-guide-card {
  margin-top: 20rpx;
}
