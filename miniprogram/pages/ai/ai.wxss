.ai-chat-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #f3f7ff 0%, #f6f8fc 160rpx, #f6f8fc 100%);
}

.ai-chat-header {
  padding: 18rpx 24rpx 10rpx;
}

.ai-pill {
  margin-bottom: 8rpx;
  background: #edf9f5;
  color: #287467;
}

.ai-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.ai-copy {
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.ai-chat-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx;
}

.ai-chat-list {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 100%;
  padding: 24rpx 0 8rpx;
}

.ai-chat-status {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.chat-row {
  display: flex;
  margin-bottom: 18rpx;
}

.chat-assistant {
  justify-content: flex-start;
}

.chat-user {
  justify-content: flex-end;
}

.chat-bubble {
  max-width: 82%;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: var(--text-primary);
  font-size: 24rpx;
  line-height: 1.7;
  box-shadow: 0 10rpx 24rpx rgba(31, 74, 159, 0.08);
}

.chat-user .chat-bubble {
  background: var(--brand);
  color: #ffffff;
}

.result-inline-card {
  margin-top: 6rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--surface-muted);
}

.result-title {
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-summary {
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.property-tag,
.follow-chip {
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(31, 94, 255, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #51607a;
  font-size: 20rpx;
}

.ai-chat-footer {
  position: sticky;
  bottom: 0;
  padding: 12rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(246, 248, 252, 0.96);
  backdrop-filter: blur(8rpx);
  border-top: 1rpx solid var(--line);
}

.quick-panel {
  margin-bottom: 12rpx;
}

.quick-panel-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 10rpx;
}

.quick-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #eef3ff 0%, #f8fbff 100%);
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 96rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #eef3ff 0%, #f8fbff 100%);
}

.quick-card-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.quick-card-copy {
  display: block;
  font-size: 18rpx;
  line-height: 1.4;
  color: var(--text-secondary);
}

.follow-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.follow-action-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #51607a;
  font-size: 20rpx;
  border: 1rpx solid rgba(31, 94, 255, 0.12);
}

.input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  min-height: 76rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  font-size: 24rpx;
  color: var(--text-primary);
  box-shadow: inset 0 0 0 1rpx rgba(31, 94, 255, 0.08);
}

.chat-send-btn {
  min-width: 100rpx;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
}
