.ai-chat-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background:
    radial-gradient(circle at 84% 5%, rgba(255, 225, 155, 0.26), transparent 26%),
    linear-gradient(180deg, #f4f5f8 0%, #f3f4f6 140rpx, #f3f4f6 100%);
}

.ai-chat-header {
  margin: 18rpx 24rpx 8rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 30, 45, 0.06);
}

.ai-pill {
  margin-bottom: 8rpx;
  background: #eef2f8;
  color: #2a3551;
}

.ai-title {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.ai-copy {
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.ai-chat-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx 6rpx;
}

.ai-chat-list {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 100%;
  padding: 24rpx 0 8rpx;
}

.chat-row {
  display: flex;
  margin-bottom: 18rpx;
}

.chat-assistant {
  justify-content: flex-start;
}

.chat-user {
  justify-content: flex-end;
}

.chat-bubble {
  max-width: 82%;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  color: var(--text-primary);
  font-size: 24rpx;
  line-height: 1.65;
  box-shadow: 0 8rpx 20rpx rgba(14, 20, 36, 0.06);
  border: 1rpx solid rgba(23, 30, 45, 0.04);
}

.chat-user .chat-bubble {
  background: linear-gradient(135deg, #1c263b 0%, #2a3653 100%);
  color: #ffffff;
}

.house-inline-panel {
  margin-top: 8rpx;
  margin-bottom: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 30, 45, 0.06);
}

.result-title {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-summary {
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.house-card-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.house-inline-card {
  box-sizing: border-box;
  width: calc(50% - 6rpx);
  overflow: hidden;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e9edf4;
}

.house-inline-cover-wrap {
  height: 102rpx;
  background: #eef3fb;
}

.house-inline-cover {
  display: block;
  width: 100%;
  height: 102rpx;
  background:
    linear-gradient(135deg, rgba(31, 94, 255, 0.12), rgba(246, 185, 76, 0.16)),
    linear-gradient(45deg, #e4ebff 0%, #f8fbff 100%);
}

.house-inline-cover-placeholder {
  height: 78rpx;
}

.house-inline-body {
  padding: 12rpx 12rpx 14rpx;
}

.house-inline-title {
  margin-bottom: 4rpx;
  font-size: 21rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
}

.house-inline-copy {
  margin-bottom: 4rpx;
  font-size: 17rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.house-inline-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 8rpx;
}

.house-inline-price {
  font-size: 21rpx;
  font-weight: 700;
  color: #da493c;
}

.house-inline-link {
  font-size: 18rpx;
  color: #2b3653;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.house-tag {
  padding: 6rpx 10rpx;
  border: 1rpx solid rgba(23, 30, 45, 0.1);
  border-radius: 999rpx;
  background: #f5f7fb;
  color: #4f5a70;
  font-size: 18rpx;
}

.ai-chat-footer {
  position: sticky;
  bottom: 0;
  padding: 8rpx 24rpx calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(243, 244, 246, 0.97);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid var(--line);
}

.quick-panel {
  margin-bottom: 8rpx;
}

.quick-panel-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 10rpx;
}

.quick-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #edf0f6;
  color: #2a3551;
  font-size: 22rpx;
  font-weight: 600;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 88rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #eef1f7;
}

.quick-card-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 21rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.quick-card-copy {
  display: block;
  font-size: 17rpx;
  line-height: 1.4;
  color: var(--text-secondary);
}

.follow-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.follow-action-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #4f5a70;
  font-size: 20rpx;
  border: 1rpx solid rgba(23, 30, 45, 0.1);
}

.input-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.chat-input {
  flex: 1;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  font-size: 24rpx;
  color: var(--text-primary);
  box-shadow: inset 0 0 0 1rpx rgba(23, 30, 45, 0.08);
}

.chat-send-btn {
  flex: none;
  width: 108rpx !important;
  min-width: 72rpx !important;
  height: 56rpx !important;
  min-height: 56rpx !important;
  line-height: 56rpx !important;
  padding: 0 !important;
  border-radius: 14rpx !important;
  font-size: 20rpx !important;
}
