<view class="ai-chat-page">
  <view class="ai-chat-header">
    <view class="pill ai-pill">在线客服</view>
    <view class="ai-title">{{serviceName}}</view>
    <view class="ai-copy">{{sending ? '正在为你整理回复' : '告诉我预算、区域、通勤和偏好，我来帮你缩小范围。'}}</view>
  </view>

  <scroll-view class="ai-chat-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="ai-chat-list">
      <view wx:if="{{sessionCard.requirementTextList.length > 0}}" class="ai-chat-status">
        <text wx:for="{{sessionCard.requirementTextList}}" wx:key="*this" class="follow-chip">{{item}}</text>
      </view>

      <view wx:for="{{messages}}" wx:key="id" class="chat-row chat-{{item.role}}">
        <view class="chat-bubble">{{item.content}}</view>
      </view>

      <view wx:for="{{resultCards}}" wx:key="title" class="result-inline-card">
        <view class="result-title">{{item.title}}</view>
        <view class="result-summary">{{item.copy}}</view>
        <view class="tag-row">
          <text wx:for="{{item.tags}}" wx:key="*this" class="property-tag">{{item}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="ai-chat-footer">
    <view class="quick-panel">
      <view class="quick-panel-head">
        <view class="quick-toggle" bindtap="togglePromptPanel">猜你想租</view>
      </view>

      <view wx:if="{{!promptCollapsed}}" class="quick-grid">
        <view
          wx:for="{{promptItems}}"
          wx:key="title"
          class="quick-card"
          bindtap="sendPreset"
          data-text="{{item.text}}"
        >
          <text class="quick-card-title">{{item.title}}</text>
          <text class="quick-card-copy">{{item.desc}}</text>
        </view>
      </view>

      <view wx:if="{{!promptCollapsed}}" class="follow-quick">
        <view
          wx:for="{{followUps}}"
          wx:key="*this"
          class="follow-action-chip"
          bindtap="sendFollowUp"
          data-text="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="input-wrap">
      <input
        class="chat-input"
        placeholder="输入你的租房需求，例如：月租 3500，近地铁，可养宠物"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="submitInput"
        confirm-type="send"
      />
      <button class="btn-primary chat-send-btn" bindtap="submitInput" loading="{{sending}}">
        发送
      </button>
    </view>
  </view>
</view>
