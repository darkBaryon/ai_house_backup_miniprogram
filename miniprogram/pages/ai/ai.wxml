<view class="ai-chat-page">
  <view class="ai-chat-header">
    <view class="pill ai-pill">在线客服</view>
    <view class="ai-title">{{serviceName}}</view>
    <view class="ai-copy">{{sending ? '正在回复...' : '说预算、区域、通勤即可'}}</view>
  </view>

  <scroll-view class="ai-chat-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="ai-chat-list">
      <view wx:for="{{messages}}" wx:key="id" class="chat-row chat-{{item.role}}">
        <view class="chat-bubble">{{item.content}}</view>
      </view>

      <view class="house-inline-panel">
        <view class="result-title">房源信息</view>
        <view wx:if="{{houseLoading}}" class="result-summary">正在为你整理房源...</view>
        <view wx:elif="{{houseLoadFailed}}" class="result-summary">房源加载失败，请稍后重试。</view>
        <view wx:elif="{{houseCards.length === 0}}" class="result-summary">暂无匹配房源，补充条件试试。</view>
        <view wx:else class="house-card-list">
          <view
            wx:for="{{houseCards}}"
            wx:key="id"
            class="house-inline-card"
            data-id="{{item.id}}"
            bindtap="openDetail"
          >
            <view wx:if="{{item.cover}}" class="house-inline-cover-wrap">
              <image
                class="house-inline-cover"
                src="{{item.cover}}"
                mode="aspectFill"
                data-index="{{index}}"
                binderror="onHouseCardImageError"
              />
            </view>
            <view wx:else class="house-inline-cover house-inline-cover-placeholder"></view>
            <view class="house-inline-body">
              <view class="house-inline-title">{{item.title}}</view>
              <view class="house-inline-copy">{{item.district}}</view>
              <view class="house-inline-copy">{{item.summary}}</view>
              <view class="house-inline-bottom">
                <text class="house-inline-price">{{item.priceText}}</text>
                <text class="house-inline-link">查看详情</text>
              </view>
              <view class="tag-row">
                <text wx:for="{{item.tags}}" wx:key="*this" class="house-tag">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="ai-chat-footer">
    <view class="quick-panel">
      <view class="quick-panel-head">
        <view class="quick-toggle" bindtap="togglePromptPanel">猜你想租</view>
      </view>

      <view wx:if="{{!promptCollapsed}}" class="quick-grid">
        <view
          wx:for="{{promptItems}}"
          wx:key="title"
          class="quick-card"
          bindtap="sendPreset"
          data-text="{{item.text}}"
        >
          <text class="quick-card-title">{{item.title}}</text>
          <text class="quick-card-copy">{{item.desc}}</text>
        </view>
      </view>

      <view wx:if="{{!promptCollapsed}}" class="follow-quick">
        <view
          wx:for="{{followUps}}"
          wx:key="*this"
          class="follow-action-chip"
          bindtap="sendFollowUp"
          data-text="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="input-wrap">
      <input
        class="chat-input"
        placeholder="输入你的租房需求"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="submitInput"
        confirm-type="send"
      />
      <button class="btn-primary chat-send-btn" bindtap="submitInput" loading="{{sending}}">
        发送
      </button>
    </view>
  </view>
</view>
