<!--index.wxml - 聊天界面-->
<view class="page">
  <scroll-view class="scroll-area" scroll-y scroll-into-view="{{scrollIntoView}}">
    <view class="message-list">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-item {{item.isUser ? 'message-user' : 'message-ai'}}"
      >
        <text class="message-content">{{item.content}}</text>
      </view>
    </view>
  </scroll-view>
  <view class="nav-link">
    <navigator url="/pages/logs/logs" open-type="navigate">查看启动日志</navigator>
  </view>
  <view class="input-bar">
    <input
      class="input"
      placeholder="输入消息"
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>
</view>
