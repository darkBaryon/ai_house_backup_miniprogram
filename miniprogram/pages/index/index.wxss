/* index.wxss - 微信风格聊天界面 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #ededed;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
  height: 0;
}

.message-list {
  padding: 24rpx 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.message-item {
  margin-bottom: 28rpx;
  max-width: 75%;
  display: flex;
}

/* 用户消息：靠右，绿色气泡 */
.message-user {
  margin-left: auto;
  flex-direction: row-reverse;
}

.message-user .message-content {
  display: inline-block;
  padding: 20rpx 28rpx;
  background: #95ec69;
  color: #000;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.5;
  max-width: 100%;
  word-break: break-all;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

/* AI 消息：靠左，白色气泡 */
.message-ai {
  margin-right: auto;
}

.message-ai .message-content {
  display: inline-block;
  padding: 20rpx 28rpx;
  background: #fff;
  color: #333;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.5;
  max-width: 100%;
  word-break: break-all;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.06);
}

.nav-link {
  padding: 12rpx 24rpx;
  text-align: center;
  background: #ededed;
}

.nav-link navigator {
  color: #576b95;
  font-size: 26rpx;
}

/* 底部输入栏：白底，类似微信 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid #e0e0e0;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

/* 发送按钮：紧凑文字样式，不抢眼 */
.send-btn {
  min-width: 96rpx;
  height: 72rpx;
  padding: 0 20rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #07c160;
  background: transparent;
  border: none;
  border-radius: 0;
}

.send-btn::after {
  border: none;
}
