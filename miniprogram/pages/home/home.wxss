.hero {
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(25, 194, 160, 0.18), transparent 36%),
    linear-gradient(160deg, #1b4dcc 0%, #1f5eff 48%, #19c2a0 100%);
  color: #ffffff;
}

.hero-top {
  margin-bottom: 24rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.brand-badge,
.city-switch {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
}

.hero-title {
  margin-bottom: 14rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-copy {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
}

.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.86);
}

.search-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.filter-scroll {
  margin: 20rpx -8rpx 0;
  white-space: nowrap;
}

.filter-row,
.match-row {
  display: inline-flex;
  padding: 8rpx;
}

.hero-pill {
  margin-right: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
}

.ai-banner {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(10, 23, 54, 0.18);
}

.ai-banner-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.ai-banner-copy {
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.shortcut-card {
  padding: 28rpx;
}

.scenario-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.scenario-item {
  min-height: 152rpx;
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, #eef3ff 0%, #f8fbff 100%);
}

.property-title,
.match-title {
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.property-copy,
.match-copy {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.shortcut-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.shortcut-subtitle {
  display: block;
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.value-card,
.flow-card,
.sample-card {
  padding: 28rpx;
}

.value-item {
  padding: 22rpx 0;
  border-top: 1rpx solid var(--line);
}

.value-item:first-of-type {
  padding-top: 0;
  border-top: 0;
}

.value-item-title,
.flow-title {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.value-item-copy,
.flow-copy,
.sample-bubble {
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.flow-step {
  display: flex;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.flow-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 700;
}

.flow-content {
  flex: 1;
}

.sample-row {
  display: flex;
  margin-bottom: 18rpx;
}

.sample-user {
  justify-content: flex-end;
}

.sample-assistant {
  justify-content: flex-start;
}

.sample-bubble {
  max-width: 88%;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: var(--surface-muted);
}

.sample-user .sample-bubble {
  background: var(--brand);
  color: #ffffff;
}

.sample-btn {
  margin-top: 12rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.property-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 20rpx;
}

.future-card {
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
}

.advisor-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
}

.advisor-copy {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
