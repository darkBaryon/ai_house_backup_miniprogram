<view class="page-shell home-page">
  <view class="section hero section-card">
    <view class="hero-top">
      <view>
        <view class="brand-row">
          <text class="brand-badge">AI House</text>
          <text class="city-switch">{{city}}</text>
        </view>
        <view class="hero-title">更聪明地找房，少走弯路</view>
        <view class="hero-copy">把预算、区域和居住需求交给 AI，我们先帮你缩小选择范围。</view>
      </view>
    </view>

    <view class="search-bar" bindtap="goToDiscover">
      <text class="search-placeholder">搜小区、区域、地铁、户型</text>
      <text class="search-action">去找房</text>
    </view>

    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="filter-row">
        <view wx:for="{{quickFilters}}" wx:key="*this" class="pill hero-pill">{{item}}</view>
      </view>
    </scroll-view>

    <view class="ai-banner">
      <view>
        <view class="ai-banner-title">告诉 AI 你的需求</view>
        <view class="ai-banner-copy">比如“预算 600 万，想要近地铁、适合一家三口”</view>
      </view>
      <button class="btn-primary" bindtap="goToAi">立即开始</button>
    </view>
  </view>

  <view class="section section-card shortcut-card">
    <view class="section-head">
      <text class="section-title">快捷入口</text>
      <text class="section-subtitle">常用找房场景</text>
    </view>
    <view class="shortcut-grid">
      <view wx:for="{{shortcuts}}" wx:key="title" class="shortcut-item shortcut-{{item.tone}}">
        <text class="shortcut-title">{{item.title}}</text>
        <text class="shortcut-subtitle">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">今日推荐</text>
      <text class="card-link" bindtap="goToDiscover">查看全部</text>
    </view>
    <view wx:for="{{todayPicks}}" wx:key="id" class="property-card section-card" bindtap="openPropertyDetail">
      <view class="property-cover cover-blue"></view>
      <view class="property-body">
        <view class="property-title">{{item.title}}</view>
        <view class="property-copy">{{item.location}}</view>
        <view class="property-copy">{{item.meta}}</view>
        <view class="tag-row">
          <text wx:for="{{item.tags}}" wx:key="*this" class="property-tag">{{item}}</text>
        </view>
        <view class="property-price-row">
          <text class="price">{{item.price}}</text>
          <text class="tiny">AI 认为这类房源兼顾通勤和家庭居住</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">AI 猜你喜欢</text>
      <text class="section-subtitle">根据目标预算生成</text>
    </view>
    <scroll-view class="match-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="match-row">
        <view wx:for="{{aiMatches}}" wx:key="id" class="match-card section-card" bindtap="openPropertyDetail">
          <view class="match-cover cover-green"></view>
          <view class="match-title">{{item.title}}</view>
          <view class="match-copy">{{item.location}}</view>
          <view class="match-copy">{{item.meta}}</view>
          <view class="tag-row">
            <text wx:for="{{item.tags}}" wx:key="*this" class="property-tag">{{item}}</text>
          </view>
          <text class="price">{{item.price}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section section-card advisor-card">
    <view>
      <view class="section-title">专属顾问 10 分钟内响应</view>
      <view class="advisor-copy">如果你已经有明确预算和区域，我们可以继续帮你细化到具体小区和户型。</view>
    </view>
    <button class="btn-ghost" bindtap="goToAi">立即咨询</button>
  </view>
</view>
