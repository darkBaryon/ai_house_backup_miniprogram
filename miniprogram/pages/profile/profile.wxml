<view class="page-shell">
  <view class="section profile-hero section-card">
    <view class="avatar">A</view>
    <view class="profile-info">
      <view class="profile-title">欢迎来到 AI House</view>
      <view class="profile-copy">登录后可以同步收藏、预约记录和 AI 推荐结果。</view>
    </view>
    <button class="btn-ghost profile-btn">立即登录</button>
  </view>

  <view class="section section-card stat-card">
    <view class="section-head">
      <text class="section-title">我的数据</text>
      <text class="section-subtitle">最近 30 天</text>
    </view>
    <view class="stat-grid">
      <view wx:for="{{stats}}" wx:key="label" class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section section-card service-card">
    <view class="section-head">
      <text class="section-title">常用服务</text>
      <text class="section-subtitle">帮助你继续推进找房</text>
    </view>
    <view wx:for="{{services}}" wx:key="*this" class="service-item">
      <text>{{item}}</text>
      <text class="service-arrow">›</text>
    </view>
  </view>

  <view class="section section-card membership-card">
    <view class="pill">后续可扩展</view>
    <view class="section-title membership-title">专属顾问与深度报告</view>
    <view class="membership-copy">如果后面要加会员、深度购房建议或一对一服务，这里可以直接承接。</view>
    <button class="btn-primary" bindtap="goToAi">咨询专属服务</button>
  </view>
</view>
