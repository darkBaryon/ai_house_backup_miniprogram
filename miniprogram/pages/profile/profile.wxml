<view class="page-shell">
  <view class="section profile-hero section-card">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-info">
      <view class="profile-title">{{profile.nickname}}</view>
      <view class="profile-copy">
        {{isLoggedIn ? '当前身份：租客' : '未登录个人中心，登录后可查看收藏、浏览与咨询记录'}}
      </view>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="btn-primary profile-btn" bindtap="onLoginTap">登录个人中心</button>
    <button wx:else class="btn-ghost profile-btn" bindtap="onSwitchRoleTap">切换角色</button>
  </view>

  <view class="section section-card stat-card">
    <view class="section-head">
      <text class="section-title">租客数据</text>
      <text class="section-subtitle">个人主页聚合</text>
    </view>
    <view class="stat-grid">
      <view wx:for="{{stats}}" wx:key="key" class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section section-card service-card">
    <view class="section-head">
      <text class="section-title">租客服务</text>
      <text class="section-subtitle">收藏、浏览、咨询与找房入口</text>
    </view>
    <view wx:for="{{actions}}" wx:key="id" class="service-item" data-id="{{item.id}}" bindtap="onActionTap">
      <view class="service-main">
        <text class="service-title">{{item.title}}</text>
        <text class="service-desc">{{item.desc}}</text>
      </view>
      <text class="service-arrow">›</text>
    </view>
  </view>

  <view class="section section-card membership-card">
    <view class="pill">租客模式说明</view>
    <view class="section-title membership-title">找房和咨询默认面向租客</view>
    <view wx:for="{{tips}}" wx:key="*this" class="membership-copy">{{item}}</view>
    <button class="btn-primary" bindtap="goToAi">咨询专属服务</button>
  </view>
</view>
