.profile-hero,
.stat-card,
.service-card,
.membership-card {
  padding: 28rpx;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f5eff 0%, #19c2a0 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-info {
  flex: 1;
}

.profile-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-copy {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.profile-btn {
  min-width: 144rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--surface-muted);
}

.stat-value {
  display: block;
  margin-bottom: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  border-top: 1rpx solid var(--line);
  font-size: 26rpx;
}

.service-item:first-of-type {
  border-top: 0;
}

.service-arrow {
  color: var(--text-tertiary);
}

.membership-title {
  margin: 18rpx 0 10rpx;
}

.membership-copy {
  margin-bottom: 22rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
