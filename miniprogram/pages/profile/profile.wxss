.profile-hero,
.stat-card,
.service-card,
.membership-card {
  padding: 28rpx;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f5eff 0%, #19c2a0 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-info {
  flex: 1;
}

.profile-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-copy {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.profile-btn {
  min-width: 144rpx;
}

.stat-grid {
  display: flex;
  gap: 12rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: var(--surface-muted);
}

.stat-value {
  display: block;
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--brand);
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-secondary);
  text-align: center;
}

.service-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--line);
}

.service-item:first-of-type {
  border-top: 0;
}

.service-main {
  flex: 1;
  min-width: 0;
}

.service-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 26rpx;
}

.service-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.service-arrow {
  margin-top: 6rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.membership-title {
  margin: 18rpx 0 10rpx;
}

.membership-copy {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.membership-copy:last-of-type {
  margin-bottom: 22rpx;
}
